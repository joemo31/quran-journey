# Server
PORT=5000
NODE_ENV=development

# Database
# Use either DATABASE_URL or the individual DB_* values below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quran_journey_lms
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSL=false

# JWT
JWT_SECRET=replace_with_a_random_32_plus_character_secret
JWT_EXPIRES_IN=7d

# Frontend origins allowed by CORS
# You can set one URL or a comma-separated list in FRONTEND_URLS.
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# Admin notifications
ADMIN_EMAIL=admin@example.com

# EmailJS
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=public_xxxxxxx
EMAILJS_PRIVATE_KEY=private_xxxxxxx

# SMTP fallback (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=Quran Journey Academy <your@email.com>

# Messaging notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ULTRAMSG_INSTANCE=
ULTRAMSG_TOKEN=
WHAPI_TOKEN=
WHATSAPP_ADMIN_NUMBER=

# Supabase Storage for persistent media uploads (recommended in production)
# Create a public bucket, for example: media
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=media
